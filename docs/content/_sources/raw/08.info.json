17-1&_nc_gid=pZ2_TyVW_D1MoaNAtrd8hA&_nc_ss=7a22e&_nc_zt=28&oh=00_Af7isLUkXt_Ohlf42Qw3rcD0UH-DUfdBCvMF6PUUd57JvQ&oe=6A1103AF", "manifest_stream_number": 0, "is_dash_periods": true, "protocol": "https", "video_ext": "mp4", "audio_ext": "none", "abr": 0, "vbr": 827.417, "resolution": "1080x1920", "aspect_ratio": 0.56, "filesize_approx": 4325218, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.instagram.com/"}, "format": "dash-938985332299219v - 1080x1920 (DASH video)"}], "title": "Video by marc.kaz", "description": "SigDigger is an open-source digital signal analyzer.\n\nShips with:\n• NOAA weather satellite images in real time\n• Aircraft transponder decoding\n• Pager, walkie-talkie & analog voice interception\n• Live waterfall + full spectrum analysis\n• Custom plugins & SoapySDR support for almost every SDR\n• Built from scratch (Suscan + Sigutils)\n\nNo license. No subscription. Just plug and dig.\n\n👉 https://github.com/BatchDrake/SigDigger\n\nWho’s listening to the skies today? Drop a 🔥", "duration": 41.819, "timestamp": 1777737328, "uploader_id": "173823625", "uploader": "Marc Kaz", "channel": "marc.kaz", "like_count": 7830, "comment_count": 112, "comments": [{"author": "el_smurfy", "author_id": "34433678", "id": "18103452673985941", "text": "Come back with updated running satsigs and viper/phase 2 signal decoding and I'm sold", "timestamp": 1779110147}, {"author": "e_laguna79", "author_id": "531361831", "id": "18008298317913408", "text": "", "timestamp": 1779064161}, {"author": "hungfut18", "author_id": "1090988014", "id": "17972803850995418", "text": "I'm dyslexic, I said it wrong.", "timestamp": 1778968518}, {"author": "gapingshanus.part2", "author_id": "63030097324", "id": "18149542735487514", "text": "I mean... all these tools have been available for a while now. No need for $40k worth of equipment 😂😂😂 someone just bundled the tools all together into one app (which is cool and useful dont get me  wrong)", "timestamp": 1778942656}, {"author": "pure.principle", "author_id": "1145981083", "id": "18122040127652509", "text": "🔥", "timestamp": 1778820167}, {"author": "alexia.builds", "author_id": "26667002861", "id": "18123505411618378", "text": "Being a developer makes me realize it’s still the wild Wild West in the internet realm there is so much access 😂😂", "timestamp": 1778691222}, {"author": "watch_your_siks", "author_id": "7800596619", "id": "18021551204831450", "text": "", "timestamp": 1778563853}, {"author": "user_179088", "author_id": "75740721909", "id": "18348660667241870", "text": "Queastion?why would i need or want to use it", "timestamp": 1778537681}, {"author": "anthonymikinka", "author_id": "326638468", "id": "18099228460847057", "text": "That’s awesome!!", "timestamp": 1778519142}], "thumbnails": [{"url": "https://instagram.ftlv6-1.fna.fbcdn.net/v/t51.71878-15/684393029_1242329014778546_5457034894481955475_n.jpg?stp=dst-jpg_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDAuc2RyLnZpZGVvX25mcmFtZV9jb3Zlcl9mcmFtZS5jMiJ9&_nc_ht=instagram.ftlv6-1.fna.fbcdn.net&_nc_cat=102&_nc_oc=Q6cZ2gEUiBfQUwrzYE9DpWQPFqdIampGoFUTUeJrbyaXqR6rKNO6l1b74iuGGfKdR9pAHM7f7EAPmky8Hhz72D8ZGFdN&_nc_ohc=yK3A9bXrn0gQ7kNvwHoDl7b&_nc_gid=pZ2_TyVW_D1MoaNAtrd8hA&edm=ANTKIIoBAAAA&ccb=7-5&oh=00_Af6M1Hv2tKA-t83wA39M_54XylZ9I6u0EKbHnEJJTRM2yw&oe=6A10EDC0&_nc_sid=d885a2", "width": 640, "height": 1136, "id": "0", "resolution": "640x1136"}, {"url": "https://instagram.ftlv6-1.fna.fbcdn.net/v/t51.71878-15/684393029_1242329014778546_5457034894481955475_n.jpg?stp=dst-jpg_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDAuc2RyLnZpZGVvX25mcmFtZV9jb3Zlcl9mcmFtZS5jMiJ9&_nc_ht=instagram.ftlv6-1.fna.fbcdn.net&_nc_cat=102&_nc_oc=Q6cZ2gEUiBfQUwrzYE9DpWQPFqdIampGoFUTUeJrbyaXqR6rKNO6l1b74iuG