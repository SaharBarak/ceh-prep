1&_nc_gid=7_M52tMikgojuFJf7KXWnw&_nc_zt=28&_nc_ss=7a22e&oh=00_Af4lJfB1qk9NTgICwNnCU3_OtWtaL9XpPnoC1iW_9ER_Cg&oe=6A111675", "manifest_stream_number": 0, "is_dash_periods": true, "protocol": "https", "video_ext": "mp4", "audio_ext": "none", "abr": 0, "vbr": 865.021, "resolution": "720x1280", "aspect_ratio": 0.56, "filesize_approx": 923950, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/142.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.instagram.com/"}, "format": "dash-3287351268113740v - 720x1280 (DASH video)"}, {"format_id": "dash-3287351261447074v", "ext": "mp4", "width": 1080, "height": 1920, "tbr": 1291.532, "format_note": "DASH video", "container": "mp4_dash", "vcodec": "vp09.00.40.08.00.01.01.01.00", "acodec": "none", "dynamic_range": "SDR", "url": "https://instagram.ftlv6-1.fna.fbcdn.net/o1/v/t2/f2/m367/AQNbsjD2LxgM2s-1vNebWxSUaViWMbM_tyiGg0exIGRz3FZdTeXJLI_QuUQWEQuGqWugiFahTHM__qcDQL1-AIUHLXxccqTielMDIP8.mp4?_nc_cat=105&_nc_oc=AdrRQbH7-ykqKAkcHdSMBvLiEvaQe8O3qFZOSFeUTCSCA0_Y7LjUrNO--v12QglT-7r3PfrzfvqX_yE38RsXT2i_&_nc_sid=9ca052&_nc_ht=instagram.ftlv6-1.fna.fbcdn.net&_nc_ohc=mR_TSpIY62IQ7kNvwFMawuB&%3D&ccb=17-1&_nc_gid=7_M52tMikgojuFJf7KXWnw&_nc_zt=28&_nc_ss=7a22e&oh=00_Af5Q5JrcfiOa_J1dPcsmht1VUkoPxlk8749obYMI6sPtxw&oe=6A111D6A", "manifest_stream_number": 0, "is_dash_periods": true, "protocol": "https", "video_ext": "mp4", "audio_ext": "none", "abr": 0, "vbr": 1291.532, "resolution": "1080x1920", "aspect_ratio": 0.56, "filesize_approx": 1379517, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/142.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.instagram.com/"}, "format": "dash-3287351261447074v - 1080x1920 (DASH video)"}], "title": "Video by kerem.tech", "description": "Companies want you to hack them. Here's where.\n\nNot theory, not CTFs. Real platforms paying real money to ethical hackers\nwho find real bugs.\n\nHackerOne — The largest and most established platform in the industry. Over\n$300M paid out since 2012. Hosts programs from Uber, Spotify, GitHub, Slack\nand the U.S. Department of Defense. Top hunters earn $250K+ per single bug.\n\nBugcrowd — Founded the same year as HackerOne. Used by OpenAI, Atlassian,\nMastercard and T-Mobile for bug bounties and managed pentests. Strong\nenterprise integration with Jira and ServiceNow.\n\nIntigriti — Europe's leading platform, based in Belgium. Backed by Microsoft,\nIntel, Red Bull, Nestle and Ubisoft. Best entry point for European hunters\nand known for the most hacker friendly UX in the industry.\n\nSynack — Invite-only with around 1,500 vetted Synack Red Team members across\n80+ countries. Hybrid hourly plus bounty model. Targets enterprise and\ngovernment clients including the IRS, Allianz and Navy Federal Credit Union.\n\nYesWeHack — French platform with strong presence in Europe and Asia. Hosts\nprograms from OVHcloud, Doctolib, Tencent and ZTE. GDPR compliant\ninfrastructure and the platform of choice for many EU public sector programs.\n\nImmunefi — The dominant Web3 platform, paying out the largest bounties in\ncybersecurity history. Awarded a $10M payout for the Wormhole bug, the\nhighest ever paid. Trusted by Chainlink, Arbitrum, MakerDAO and most top\nDeFi protocols.\n\nHackenProof — Web3 bounty platform from the Hacken security group. $22M+\npaid to hackers, 70K+ researchers. Hosts programs for Gate.io, NEAR,\nMetaMask, Aptos and Polygon. More accessible alternative to Immunefi.\n\nSave this. Share with the friend who thinks hacking doesn't pay.\n\n#cybersecurity #bugbounty #ethicalhacking #infosec #securityresearch", "duration": 8.545,