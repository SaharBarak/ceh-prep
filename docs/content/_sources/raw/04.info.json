=9ca052&_nc_ht=instagram.ftlv6-1.fna.fbcdn.net&_nc_ohc=Ie4vuLORu84Q7kNvwH1EFTQ&%3D&ccb=17-1&_nc_gid=ul5oWEamdoSu6Z1ByyvU5w&_nc_zt=28&_nc_ss=7a22e&oh=00_Af5JuJFlplCDZ7acC0UAYTKm_V9QTxbuSCKh701WiS-3pw&oe=6A111B0C", "manifest_stream_number": 0, "is_dash_periods": true, "protocol": "https", "video_ext": "mp4", "audio_ext": "none", "abr": 0, "vbr": 838.482, "resolution": "720x1280", "aspect_ratio": 0.56, "filesize_approx": 752013, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/137.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.instagram.com/"}, "format": "dash-2330657924096351v - 720x1280 (DASH video)"}, {"format_id": "dash-1693546975133332v", "ext": "mp4", "width": 1080, "height": 1920, "tbr": 1207.141, "format_note": "DASH video", "container": "mp4_dash", "vcodec": "vp09.00.40.08.00.01.01.01.00", "acodec": "none", "dynamic_range": "SDR", "url": "https://instagram.ftlv5-1.fna.fbcdn.net/o1/v/t2/f2/m367/AQNLZo1vKnJ-fwUPSWDzbBsZXqG361_kyuCeYdQPvSXURsJZuCkdKnQwzw3i1HztAIAb5pCl74668S177QBQHlsWUl6qB3Oi1DpcB4Y.mp4?_nc_cat=109&_nc_oc=AdqOlFjnCw4t0EYekee7vcIGBiJ0QuiITlnlozZQY8wGIhDzJh0Y1kOiOYcjmvWf7ubfamqGj0632RPMWRtSRFyL&_nc_sid=9ca052&_nc_ht=instagram.ftlv5-1.fna.fbcdn.net&_nc_ohc=X3gZqkDJVkAQ7kNvwG60qdq&&ccb=17-1&_nc_gid=ul5oWEamdoSu6Z1ByyvU5w&_nc_zt=28&_nc_ss=7a22e&oh=00_Af5DuSvQrYbgLzaypvetj7zt97B6XwcfitgErr3g_K9SUg&oe=6A110D0E", "manifest_stream_number": 0, "is_dash_periods": true, "protocol": "https", "video_ext": "mp4", "audio_ext": "none", "abr": 0, "vbr": 1207.141, "resolution": "1080x1920", "aspect_ratio": 0.56, "filesize_approx": 1082654, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/137.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.instagram.com/"}, "format": "dash-1693546975133332v - 1080x1920 (DASH video)"}], "title": "Video by kerem.tech", "description": "SQL injection has been in OWASP's top risks for over 20 years. SQLMap is still the tool that automates almost every step of exploiting it.\n\nPoint it at a vulnerable URL and it figures out the DBMS, the injection type, and the backend version for you. From there it is a few flags to the data.\n\nWhat it does in one workflow:\n\n-> Detect vulnerable parameters with a single command\n-> Enumerate every database, table, and column\n-> Dump real rows from specific columns, not entire tables\n-> Replay full POST requests with cookies and headers intact\n-> Crank level and risk to surface hidden injection points\n-> Bypass WAFs with tamper scripts\n-> Escalate a DB bug into an OS shell on the host\n\nIf you work in web pentesting, bug bounty, or appsec, these commands come up in almost every engagement.\n\nOnly use SQLMap on targets you own or have explicit permission to test.\n\nSave this for the next time you hit a parameter that looks suspicious.\n\n#sqlmap #sqlinjection #pentesting #bugbounty #cybersecurity", "duration": 7.175, "timestamp": 1776515135, "uploader_id": "54638301196", "uploader": "Kerem 🛡 Cyber Security Engineer", "channel": "kerem.tech", "like_count": 313, "comment_count": 7, "comments": [{"author": "a1688529", "author_id": "59136384114", "id": "18050168543723479", "text": "Do you have any recommendations for Cyber Forensics? Tools or helpful resources?", "timestamp": 1776664207}, {"author": "_rxmu.01_", "author_id": "64001234831", "id": "17860537665684704", "text": "👏👏🔥", "timestamp": 1776616651}, {"author": "jeanfelipenunes", "author_id": "581141686", "id": "17950981914124160", "text": "Acho que essa música na combina com o material 😂", "timestamp": 1776565966}, {"author": "kerem.tech", "author_id": "54638301196", "id": "18077654885171300", "text": "SQL injection has been in OWASP's top risks for over 20 years. SQLMap is still the tool that automates almost every step of exploiting it.\n\nPoint it at a vulnerable URL and it figures out the DBMS, the injection type, and the backend version for you. From there it is a few flags to the data.\n\nWhat it does in one workflow:\n\n-> Detect vulnerable parameters with a single command\n-> Enumerate every database, table, and column\n-> Dump real rows from specific columns, not entire tables\n-> Replay full POST requests with cookies and headers intact\n-> Crank level and risk to surface hidden injection points\n-> Bypass WAFs with tamper scripts\n-> Escalate a DB bug into an OS shell on the host\n\nIf you work in web pentesting, bug bounty, or appsec, these commands come up in almost every engagement.\n\nOnly use SQLMap on targets you own or have explicit permission to test.\n\nSave this for the next time you hit a parameter that looks suspicious.\n\n#sqlmap #sqlinjection #pentesting #bugbounty #cybersecurity", "timestamp": 1776515155}], "thumbnails": [{"url": "https://instagram.ftlv6-1.fna.fbcdn.net/v/t51.71878-15/670551883_1260539082460128_6309796052301433621_n.jpg?se=-1&stp=dst-jpegr_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDAuaGRyLnZpZGVvX2RlZmF1bHRfY292ZXJfZnJhbWUuYzIifQ&_nc_ht=instagram.ftlv6-1.fna.fbcdn.net&_nc_cat=100&_nc_oc=Q6cZ2gEqoRvkL3dVz4MiML56u7OHJ7hBMFErELP-dk3uFrgy9x70zLolMYT6Dh742GJUjuNWlpP8eULXbTT1KVESmFEi&_nc_ohc=qvw9wQKRFX4Q7kNvwGfE7qt&_nc_gid=ul5oWEamdoSu6Z1ByyvU5w&edm=ANTKIIoBAAAA&ccb=7-5&oh=00_Af6414TBPC3rFS-dnM9eNAWnBHFAl6xnxCZma5OSXAgPUQ&oe=6A10F43C&_nc_sid=d885a2", "width": 640, "height": 1136, "id": "0", "resolution": "640x1136"}, {"url": "https://instagram.ftlv6-1.fna.fbcdn.net/v/t51.71878-15/670551883_1260539082460128_6309796052301433621_n.jpg?se=-1&stp=dst-jpegr_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDAuaGRyLnZpZGVvX2RlZmF1bHRfY292ZXJfZnJhbWUuYzIifQ&_nc_ht=instagram.ftlv6-1.fna.fbcdn.net&_nc_cat