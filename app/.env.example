# ─────────────────────────────
# MongoDB
# ─────────────────────────────
# Three options, pick one. The default ("memory://") needs zero setup.
#
# 1. (DEFAULT) In-process via mongodb-memory-server. Boots in ~2s. Wiped on every
#    dev process restart. Requires zero infrastructure. Best for fresh clones.
#      MONGO_URI=memory://
#
# 2. Local Docker Compose. Persistent across restarts. Requires Docker.
#    Run from the app/ directory:
#      docker compose up -d
#    Then:
#      MONGO_URI=mongodb://localhost:27017/ceh-prep
#
# 3. MongoDB Atlas (production). M0 free tier works for development too.
#    Get the SRV string from Atlas → Cluster → Connect → Drivers:
#      MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/ceh-prep?retryWrites=true&w=majority
#
MONGO_URI=memory://

# ─────────────────────────────
# iron-session secret
# ─────────────────────────────
# MUST be at least 32 chars, random. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=change-me-to-a-real-48-byte-random-string-before-running

# Cookie name (optional — defaults to ceh_session)
SESSION_COOKIE_NAME=ceh_session

# ─────────────────────────────
# Public app URL (used for Origin-header CSRF defense in server actions)
# ─────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────
# Cron + marketing email (Phase 10 + 11)
# ─────────────────────────────
# Bearer token that gates /api/cron/* — Vercel Cron sets
# `Authorization: Bearer ${CRON_SECRET}` on every invocation. The route
# verifies via constant-time compare. Generate:
#   openssl rand -base64 32
CRON_SECRET=change-me-rotate-on-deploy

# HMAC signing key for marketing-email unsubscribe tokens. Separate from
# SESSION_SECRET so unsub links survive session-secret rotation. Generate:
#   openssl rand -base64 32
UNSUB_SECRET=change-me-rotate-on-deploy
