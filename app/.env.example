# ============================================================
# CEH Sprint — environment template
# ============================================================
# Copy to .env.local for development, or paste these vars into
# Railway's "Variables" tab for production. Never commit .env files
# with real values — only this .example template is tracked.
#
# Generate strong secrets via:    openssl rand -base64 48
# ============================================================

# ─────────────────────────────
# Public app URL
# ─────────────────────────────
# Origin used for: CSRF defense on server actions, absolute links in
# emails, canonical OG/SEO metadata. Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────
# MongoDB
# ─────────────────────────────
# Dev options:
#   memory://                                          (in-process, default)
#   mongodb://localhost:27017/ceh-prep                 (docker compose up -d)
#
# Production (MongoDB Atlas):
#   mongodb+srv://USER:PASS@CLUSTER.mongodb.net/ceh-prep?retryWrites=true&w=majority
#
# Atlas notes for Railway:
# - Allowlist 0.0.0.0/0 OR Railway's egress IPs.
# - M0 free tier: 512MB storage, 100 conn cap. The mongoose pool is
#   tuned for this (maxPoolSize=5).
MONGO_URI=memory://

# ─────────────────────────────
# Session (iron-session)
# ─────────────────────────────
# MUST be 32+ chars, random, kept secret. Rotation invalidates active
# sessions. Generate: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-real-48-byte-random-string-before-running
SESSION_COOKIE_NAME=ceh_session

# ─────────────────────────────
# Cron (Phase 10 — drip & engagement emails)
# ─────────────────────────────
# Bearer token gating /api/cron/drip and /api/cron/engagement. The cron
# scheduler (Railway Cron, GitHub Actions, cron-job.org, etc.) sends:
#   Authorization: Bearer ${CRON_SECRET}
# Generate: openssl rand -base64 32
CRON_SECRET=change-me-rotate-on-deploy

# HMAC signing key for unsubscribe links. Separate from SESSION_SECRET
# so unsub links survive session rotation. Generate: openssl rand -base64 32
UNSUB_SECRET=change-me-rotate-on-deploy

# ─────────────────────────────
# Resend (Phase 2 — transactional + marketing email)
# ─────────────────────────────
# API key from https://resend.com/api-keys (production scope).
# Required in production. Dev path falls back to console-log stub when unset.
RESEND_API_KEY=

# Verified sender. Production: must use a domain you've verified in
# Resend (SPF + DKIM DNS records published). Format:
#   "Display Name <noreply@your-domain.com>"
RESEND_FROM_ADDRESS="CEH Sprint <no-reply@localhost>"

# Optional: Audience ID for the public marketing newsletter list.
# Without this, newsletter signups land in Mongo only; with it, they
# also sync to a Resend Audience for broadcast campaigns.
# Format: aud_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RESEND_AUDIENCE_ID=

# ─────────────────────────────
# Paddle (Phase 4 — Pro subscription billing)
# ─────────────────────────────
# ALL FOUR REQUIRED TOGETHER. Partial config fails env validation.
# Get from https://vendors.paddle.com (or sandbox.paddle.com for testing).
#
# Server-side API key (Paddle dashboard → Developer Tools → Authentication):
PADDLE_API_KEY=

# Webhook signing secret (Paddle dashboard → Developer Tools → Notifications):
PADDLE_WEBHOOK_SECRET=

# Pro tier Price ID (Paddle dashboard → Catalog → Products → your Pro product → Pricing):
PADDLE_PRO_PRICE_ID=

# Client-side token, used by the checkout overlay (Paddle dashboard →
# Developer Tools → Authentication → Client-side tokens). Public — fine
# to expose in client bundle.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# Environment: "sandbox" for testing, "production" for live billing.
NEXT_PUBLIC_PADDLE_ENV=sandbox

# ─────────────────────────────
# Google Analytics (optional)
# ─────────────────────────────
# Public — embedded in client bundle. Falsy disables tracking entirely.
# Format: G-XXXXXXXXXX (Google Analytics 4 measurement ID).
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
